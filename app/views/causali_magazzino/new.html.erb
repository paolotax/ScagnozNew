<div class="px-4 py-6 sm:px-0">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Nuova Causale Magazzino</h1>
    <%= link_to "Torna alla lista", causali_magazzino_path, 
        class: "bg-gray-600 hover:bg-gray-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <div class="bg-white shadow sm:rounded-lg">
    <div class="px-4 py-5 sm:p-6">
      <%= form_with(model: @causale_magazzino, local: true, class: "space-y-6") do |form| %>
        <% if @causale_magazzino.errors.any? %>
          <div class="rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">
                  <%= pluralize(@causale_magazzino.errors.count, "errore") %> impediscono il salvataggio:
                </h3>
                <div class="mt-2 text-sm text-red-700">
                  <ul class="list-disc pl-5 space-y-1">
                    <% @causale_magazzino.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div>
            <%= form.label :codice, class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :codice, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Es. CAR001" %>
            <p class="mt-2 text-sm text-gray-500">Codice univoco della causale (max 6 caratteri)</p>
          </div>

          <div>
            <%= form.label :nome, class: "block text-sm font-medium text-gray-700" %>
            <%= form.text_field :nome, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Es. Carico da fornitore" %>
          </div>
        </div>

        <div>
          <%= form.label :descrizione, class: "block text-sm font-medium text-gray-700" %>
          <%= form.text_area :descrizione, rows: 3, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Descrizione dettagliata della causale" %>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div>
            <%= form.label :tipo_movimento, class: "block text-sm font-medium text-gray-700" %>
            <%= form.select :tipo_movimento, options_for_select([
              ['Carico', 0],
              ['Scarico', 1], 
              ['Trasferimento', 2]
            ], @causale_magazzino.tipo_movimento_before_type_cast), {}, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>

          <div>
            <%= form.label :segno_movimento, class: "block text-sm font-medium text-gray-700" %>
            <%= form.select :segno_movimento, options_for_select([
              ['Carico (+)', 1],
              ['Scarico (-)', -1],
              ['Neutro (0)', 0]
            ], @causale_magazzino.segno_movimento), {}, class: "mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div class="flex items-center">
            <%= form.check_box :attiva, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
            <%= form.label :attiva, "Attiva", class: "ml-2 block text-sm text-gray-900" %>
          </div>

          <div class="flex items-center">
            <%= form.check_box :di_sistema, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
            <%= form.label :di_sistema, "Di Sistema", class: "ml-2 block text-sm text-gray-900" %>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
          <div class="flex items-center">
            <%= form.check_box :richiede_fornitore, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
            <%= form.label :richiede_fornitore, "Richiede Fornitore", class: "ml-2 block text-sm text-gray-900" %>
          </div>

          <div class="flex items-center">
            <%= form.check_box :richiede_cliente, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" %>
            <%= form.label :richiede_cliente, "Richiede Cliente", class: "ml-2 block text-sm text-gray-900" %>
          </div>
        </div>

        <div class="flex justify-end space-x-3">
          <%= link_to "Annulla", causali_magazzino_path, 
              class: "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
          <%= form.submit "Crea Causale", class: "bg-indigo-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
