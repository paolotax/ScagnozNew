<div class="px-4 py-6 sm:px-0">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-900">Causali Magazzino</h1>
    <%= link_to "Nuova Causale", new_causale_magazzino_path, 
        class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded" %>
  </div>

  <div class="bg-white shadow overflow-hidden sm:rounded-md">
    <ul class="divide-y divide-gray-200">
      <% @causali_magazzino.each do |causale| %>
        <li>
          <div class="px-4 py-4 flex items-center justify-between">
            <div class="flex items-center">
              <div class="flex-shrink-0">
                <div class="h-10 w-10 rounded-full bg-gray-200 flex items-center justify-center">
                  <span class="text-sm font-medium text-gray-700"><%= causale.codice %></span>
                </div>
              </div>
              <div class="ml-4">
                <div class="text-sm font-medium text-gray-900"><%= causale.nome %></div>
                <div class="text-sm text-gray-500">
                  <%= causale.tipo_movimento.humanize %> - 
                  <%= causale.segno_movimento > 0 ? "Carico" : causale.segno_movimento < 0 ? "Scarico" : "Neutro" %>
                  <% if causale.di_sistema %>
                    <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      Sistema
                    </span>
                  <% end %>
                  <% unless causale.attiva %>
                    <span class="ml-2 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                      Inattiva
                    </span>
                  <% end %>
                </div>
              </div>
            </div>
            <div class="flex space-x-2">
              <%= link_to "Visualizza", causale, 
                  class: "text-blue-600 hover:text-blue-900 text-sm font-medium" %>
              <%= link_to "Modifica", edit_causale_magazzino_path(causale), 
                  class: "text-indigo-600 hover:text-indigo-900 text-sm font-medium" %>
              <%= link_to "Elimina", causale, method: :delete, 
                  data: { confirm: "Sei sicuro di voler eliminare questa causale?" },
                  class: "text-red-600 hover:text-red-900 text-sm font-medium" %>
            </div>
          </div>
        </li>
      <% end %>
    </ul>
  </div>
</div>
